# ─── Required ───────────────────────────────────────────────
REQDESK_API_KEY=rqd_pk_your_project_key       # Reqdesk dashboard → Project → API Keys
REQDESK_API_URL=https://app.reqdesk.com       # omit to use the production default

# ─── Required for Signed host-app identity (recommended) ────
# When set, authenticated Laravel users are HMAC-signed and skip the email prompt.
REQDESK_SIGNING_SECRET=                       # Reqdesk dashboard → Project → Widget identity

# ─── Optional: appearance ───────────────────────────────────
REQDESK_THEME_PRIMARY=#0F5E56
REQDESK_THEME_MODE=auto                       # light|dark|auto
REQDESK_THEME_RADIUS=6px
REQDESK_THEME_FONT=
REQDESK_THEME_ZINDEX=9999
REQDESK_LOGO_URL=
REQDESK_BRAND_NAME=
REQDESK_HIDE_BRANDING=false

# ─── Optional: layout ───────────────────────────────────────
REQDESK_POSITION=bottom-end                   # bottom-end|bottom-start|top-end|top-start
REQDESK_DISPLAY_MODE=popover                  # popover|side-sheet|bottom-sheet
REQDESK_DISPLAY_SIDE=end                      # start|end (side-sheet only)
REQDESK_DISPLAY_WIDTH=420px
REQDESK_DISPLAY_HEIGHT=55vh
REQDESK_DISPLAY_DISMISS=true
REQDESK_HIDE_FAB=false
REQDESK_HIDE_PICKER=false
REQDESK_FAB_ICON=help                         # chat|help or raw SVG path d

# ─── Optional: localization & behavior ──────────────────────
REQDESK_LANGUAGE=en                           # en|ar
REQDESK_WIDGET_MODE=ticket-form               # ticket-form|support-portal
REQDESK_AUTH_MODE_SIGNED=signed               # comma list: signed,email,sso
REQDESK_AUTH_MODE_ANON=email                  # modes applied to anonymous visitors
REQDESK_USER_RESOLVER=                        # FQCN; leave blank for DefaultUserResolver

# ─── Optional: distribution & runtime ───────────────────────
REQDESK_ENABLED=true
REQDESK_INJECT_GUESTS=false                   # also render widget for unauthenticated visitors
REQDESK_PANELS=                               # comma list of panel IDs; empty = all panels
REQDESK_SCRIPT_URL=                           # override CDN; empty = pinned unpkg URL
REQDESK_STRICT=false                          # throw on missing config at boot (staging/dev only)

# ─── Optional: identity endpoint ────────────────────────────
REQDESK_IDENTITY_ENDPOINT=/reqdesk/widget/identity
REQDESK_IDENTITY_MIDDLEWARE=web,auth          # comma list; applied to the sign route
